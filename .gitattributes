# Normalize line endings to avoid CRLF/LF churn across platforms.
* text=auto

# Source and config files are always LF in the repo.
*.py   text eol=lf
*.go   text eol=lf
*.json text eol=lf
*.md   text eol=lf
Makefile text eol=lf

# Treat compiled/binary artifacts as binary (no normalization).
*.pyc binary
